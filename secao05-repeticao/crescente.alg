Algoritmo "Crescente"

Var
  X, Y : inteiro
Inicio
Escreva("Digite dois números!")
   leia(X)
   leia(Y)
   enquanto X <> Y faca
     se X < Y entao
       Escreval("Crescente")
       senao
       Escreval("Decrescente")
     fimse
     
     Escreva("Digite dois números!")
     Leia(X)
     Leia(Y)
     
   fimenquanto

Fimalgoritmo
